{
  "name": "8-Bit",
  "data_bus": { "width": 8 },
  "address_bus": { "width": 16 },
  "memory": { "size": 65536 },
  "registers": {
    "general_purpose": [
      { "name": "R0", "width": 8, "initial": 0 },
      { "name": "R1", "width": 8, "initial": 0 },
      { "name": "R2", "width": 8, "initial": 0 },
      { "name": "R3", "width": 8, "initial": 0 }
    ],
    "special": [
      { "name": "PC", "width": 16, "initial": 0, "role": "program_counter" },
      { "name": "SP", "width": 16, "initial": 65535, "role": "stack_pointer" },
      { "name": "FLAGS", "width": 8, "initial": 0, "role": "status_flags" }
    ]
  },
  "alu": {
    "flags": [
      { "name": "Z", "bit": 0, "type": "zero" },
      { "name": "C", "bit": 1, "type": "carry" },
      { "name": "O", "bit": 2, "type": "overflow" },
      { "name": "N", "bit": 3, "type": "negative" }
    ],
    "operations": [
      { 
        "name": "ADD", "expression": "a + b", 
        "flag_rules": { "Z": "result_zero", "C": "carry_add", "V": "overflow_add", "N": "result_negative" } 
      },
      { 
        "name": "SUB", "expression": "a - b", "latency": 8, 
        "flag_rules": { "Z": "result_zero", "C": "carry_sub", "V": "overflow_sub", "N": "result_negative" } 
      },
      { 
        "name": "AND", "expression": "a & b", 
        "flag_rules": { "Z": "result_zero", "N": "result_negative" } 
      },
      { 
        "name": "OR",  "expression": "a | b", 
        "flag_rules": { "Z": "result_zero", "N": "result_negative" } 
      },
      { 
        "name": "XOR", "expression": "a ^ b", 
        "flag_rules": { "Z": "result_zero", "N": "result_negative" } 
      },
      { 
        "name": "NOT", "expression": "~a", 
        "flag_rules": { "Z": "result_zero", "N": "result_negative" } 
      }
    ]
  },
  "instruction_set": {
    "instructions": [
      {
        "name": "NOP",
        "opcode": 0,
        "encoding": [0],
        "microcode": [ { "action": "copy", "source": "$PC", "dest": "$PC" } ]
      },
      {
        "name": "MOV",
        "opcode": 1,
        "encoding": [1, "dest", "src"],
        "microcode": [ { "action": "copy", "source": "@src", "dest": "@dest" } ]
      },
      {
        "name": "LDI",
        "opcode": 2,
        "encoding": [2, "dest", "imm8"],
        "microcode": [ { "action": "copy", "source": "@imm8", "dest": "@dest" } ]
      },
      {
        "name": "LOAD",
        "opcode": 3,
        "encoding": [3, "dest", "addr_reg"],
        "microcode": [ { "action": "mem_read", "addr": "@addr_reg", "out": "@dest" } ]
      },
      {
        "name": "STORE",
        "opcode": 4,
        "encoding": [4, "src", "addr_reg"],
        "microcode": [ { "action": "mem_write", "addr": "@addr_reg", "data": "@src" } ]
      },
      {
        "name": "ADD",
        "opcode": 5,
        "encoding": [5, "dest", "src"],
        "microcode": [ { "action": "alu", "op": "ADD", "a": "@dest", "b": "@src", "out": "@dest", "update_flags": "true" } ]
      },
      {
        "name": "SUB",
        "opcode": 6,
        "encoding": [6, "dest", "src"],
        "microcode": [ { "action": "alu", "op": "SUB", "a": "@dest", "b": "@src", "out": "@dest", "update_flags": "true" } ]
      },
      {
        "name": "SUB",
        "opcode": 14,
        "encoding": [14, "dest", "imm8"],
        "microcode": [ { "action": "alu", "op": "SUB", "a": "@dest", "b": "@imm8", "out": "@dest", "update_flags": "true" } ]
      },
      {
        "name": "JMP",
        "opcode": 7,
        "encoding": [7, "address"],
        "microcode": [ { "action": "branch", "target": "@address" } ]
      },
      {
        "name": "JZ",
        "opcode": 8,
        "encoding": [8, "address"],
        "microcode": [ { "action": "branch", "condition": "Z", "target": "@address" } ]
      },
      {
        "name": "PUSH",
        "opcode": 9,
        "encoding": [9, "src"],
        "microcode": [
          { "action": "alu", "op": "SUB", "a": "$SP", "b": "#1", "out": "$SP" },
          { "action": "mem_write", "addr": "$SP", "data": "@src" }
        ]
      },
      {
        "name": "POP",
        "opcode": 10,
        "encoding": [10, "dest"],
        "microcode": [
          { "action": "mem_read", "addr": "$SP", "out": "@dest" },
          { "action": "alu", "op": "ADD", "a": "$SP", "b": "#1", "out": "$SP" }
        ]
      },
      {
        "name": "CALL",
        "opcode": 11,
        "encoding": [11, "address"],
        "microcode": [
          { "action": "alu", "op": "SUB", "a": "$SP", "b": "#2", "out": "$SP" },
          { "action": "mem_write", "addr": "$SP", "data": "$NEXT_PC" },
          { "action": "branch", "target": "@address" }
        ]
      },
      {
        "name": "RET",
        "opcode": 12,
        "encoding": [12],
        "microcode": [
          { "action": "mem_read", "addr": "$SP", "out": "$PC" },
          { "action": "alu", "op": "ADD", "a": "$SP", "b": "#2", "out": "$SP" }
        ]
      },
      {
        "name": "JNZ",
        "opcode": 13,
        "encoding": [13, "address"],
        "microcode": [ { "action": "branch", "condition": "!Z", "target": "@address" } ]
      },
      {
        "name": "HLT",
        "opcode": 15,
        "encoding": [15],
        "microcode": [ { "action": "halt" } ]
      },
      {
        "name": "JC",
        "opcode": 16,
        "encoding": [16, "address"],
        "microcode": [ { "action": "branch", "condition": "C", "target": "@address" } ]
      }
    ]
  },
  "peripherals": [
    {
      "name": "SerialTerminal",
      "type": "text_display",
      "address_start": "0x00AA",
      "address_end": "0x00AF"
    },
    {
      "name": "MathCoProcessor",
      "type": "declarative",
      "address_start": "0x0080",
      "address_end": "0x0083",
      "registers": [
        { "name": "OP_A", "offset": 0, "size_bytes": 1, "access": "rw", "initial": 0 },
        { "name": "OP_B", "offset": 1, "size_bytes": 1, "access": "rw", "initial": 0 },
        { "name": "RESULT", "offset": 2, "size_bytes": 1, "access": "r", "initial": 0 },
        {
          "name": "CMD",
          "offset": 3,
          "size_bytes": 1,
          "access": "w",
          "initial": 0,
          "on_write": [
            {
              "type": "if",
              "condition": "value == 1",
              "then": [ { "type": "assign", "target": "RESULT", "expr": "OP_A * OP_B" } ]
            },
            {
              "type": "if",
              "condition": "value == 2",
              "then": [ { "type": "assign", "target": "RESULT", "expr": "OP_A / OP_B" } ]
            }
          ]
        }
      ]
    },
    {
      "name": "SystemTimer",
      "type": "declarative",
      "address_start": "0x0090",
      "address_end": "0x0090",
      "registers": [
        { "name": "TICKS", "offset": 0, "size_bytes": 1, "access": "r", "initial": 0 }
      ],
      "tick_behavior": [
        { "type": "assign", "target": "TICKS", "expr": "TICKS + 1" }
      ]
    },
    {
      "name": "DeclarativeUART",
      "type": "declarative",
      "address_start": "0x00AA",
      "address_end": "0x00AB",
      "registers": [
        {
          "name": "UART_TX",
          "offset": 0,
          "size_bytes": 1,
          "access": "w",
          "initial": 0,
          "on_write": [
            { "type": "call", "func": "host_print", "args": ["value"] }
          ]
        }
      ]
    }
  ]
}
